<Application
    x:Class="CloudflareDdns.Gui.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:inf="clr-namespace:CloudflareDdns.Gui.Infrastructure"
    StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <inf:BoolToVisibilityConverter x:Key="BoolToVis" />
            <inf:NotEmptyToVisibilityConverter x:Key="NotEmptyToVis" />
            <inf:StatusToBrushConverter x:Key="StatusToBrush" />
            <inf:LogLevelToBrushConverter x:Key="LogLevelToBrush" />
            <inf:InverseBoolConverter x:Key="InverseBool" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
