<Window
    x:Class="CloudflareDdns.Gui.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:CloudflareDdns.Gui.ViewModels"
    Title="Cloudflare DDNS · Control Panel"
    Height="760" Width="1080" MinHeight="620" MinWidth="940"
    Background="{StaticResource BgBrush}"
    FontFamily="{StaticResource UiFont}"
    WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ══════════════════════════ Header ══════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1" Padding="22,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="38" Height="38" CornerRadius="9" Background="{StaticResource AccentBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="☁" FontSize="20" Foreground="#111417"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Cloudflare DDNS" Style="{StaticResource H1}" FontSize="18" />
                        <TextBlock Text="Dynamic DNS control panel" Style="{StaticResource Muted}" />
                    </StackPanel>
                </StackPanel>

                <!-- Service status pill -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="12,7" VerticalAlignment="Center"
                        CornerRadius="20">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                                 Fill="{Binding ServiceStatusKey, Converter={StaticResource StatusToBrush}}" />
                        <TextBlock Text="Service" Style="{StaticResource Muted}" Margin="9,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ServiceStatus}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Content="⟳" Style="{StaticResource Chip}" Margin="12,0,0,0" Padding="8,3"
                                Command="{Binding RefreshCommand}" ToolTip="Refresh status &amp; records" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════ Tabs ══════════════════════════ -->
        <TabControl Grid.Row="1" Margin="14,10,14,0" Background="Transparent">

            <!-- ───────────── Dashboard ───────────── -->
            <TabItem Header="Dashboard">
                <Grid Margin="8,14,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Top cards -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.3*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Public IP hero -->
                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="PUBLIC IP (WAN)" Style="{StaticResource SectionLabel}" />
                                    <TextBlock Text="{Binding PublicIp}" Style="{StaticResource Mono}" FontSize="34"
                                               FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <StackPanel Margin="0,0,26,0">
                                            <TextBlock Text="CACHED IP" Style="{StaticResource SectionLabel}" Margin="0,0,0,2" />
                                            <TextBlock Text="{Binding CachedIp}" Style="{StaticResource Mono}" FontSize="13" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,26,0">
                                            <TextBlock Text="LAST CHECKED" Style="{StaticResource SectionLabel}" Margin="0,0,0,2" />
                                            <TextBlock Text="{Binding LastChecked}" Style="{StaticResource Muted}" FontSize="13" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="LAST UPDATED" Style="{StaticResource SectionLabel}" Margin="0,0,0,2" />
                                            <TextBlock Text="{Binding LastUpdated}" Style="{StaticResource Muted}" FontSize="13" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                    <Button Content="Check IP" Style="{StaticResource Ghost}" Width="104"
                                            Command="{Binding CheckIpCommand}" />
                                    <Button Content="Copy" Style="{StaticResource Chip}" Width="104" Margin="0,8,0,0"
                                            Command="{Binding CopyIpCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Actions -->
                        <Border Grid.Column="2" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="ACTIONS" Style="{StaticResource SectionLabel}" />
                                <Button Content="⟳  Sync now" Style="{StaticResource Primary}" Margin="0,2,0,0"
                                        Command="{Binding SyncNowCommand}"
                                        ToolTip="Run one full reconcile pass and write changes to Cloudflare" />
                                <Button Content="◎  Dry-run preview" Style="{StaticResource Ghost}" Margin="0,8,0,0"
                                        Command="{Binding DryRunCommand}"
                                        ToolTip="Show exactly what would change — writes nothing" />
                                <Button Content="+  Create missing records" Style="{StaticResource Ghost}" Margin="0,8,0,0"
                                        Command="{Binding CreateMissingCommand}"
                                        ToolTip="Create an A record for every managed hostname that doesn't have one yet — existing records are left untouched" />
                                <Button Content="↻  Refresh records" Style="{StaticResource Ghost}" Margin="0,8,0,0"
                                        Command="{Binding RefreshCommand}" />
                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,14,0,12" />
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,20,0">
                                        <TextBlock Text="{Binding MatchCount}" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource OkBrush}" />
                                        <TextBlock Text="up to date" Style="{StaticResource Muted}" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="{Binding IssueCount}" FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource WarnBrush}" />
                                        <TextBlock Text="need attention" Style="{StaticResource Muted}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Hostname table -->
                    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,14,0,0" Padding="6">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Margin="12,10,12,4">
                                <TextBlock Text="Managed hostnames" Style="{StaticResource H2}" />
                                <TextBlock Text="{Binding DashboardHint}" Style="{StaticResource Muted}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" MaxWidth="520" />
                            </Grid>
                            <DataGrid Grid.Row="1" ItemsSource="{Binding Hosts}" Margin="4,4,4,4">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="STATUS" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                                                             Fill="{Binding Status, Converter={StaticResource StatusToBrush}}" />
                                                    <TextBlock Text="{Binding Status}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="HOSTNAME" Width="2*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock VerticalAlignment="Center" FontFamily="{StaticResource MonoFont}"
                                                           ToolTip="Open https:// this hostname in your browser">
                                                    <Hyperlink
                                                        Command="{Binding DataContext.OpenHostnameCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding Hostname}">
                                                        <Run Text="{Binding Hostname, Mode=OneWay}" />
                                                    </Hyperlink>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="ZONE" Binding="{Binding Zone}" Width="*" />
                                    <DataGridTextColumn Header="RECORD IP" Binding="{Binding CurrentIp}" Width="Auto" />
                                    <DataGridTextColumn Header="PROXY" Binding="{Binding ProxiedText}" Width="Auto" />
                                    <DataGridTextColumn Header="DETAIL" Binding="{Binding Detail}" Width="1.4*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ───────────── Configuration ───────────── -->
            <TabItem Header="Configuration">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,10,8,8">
                    <StackPanel MaxWidth="900" HorizontalAlignment="Left">

                        <!-- API token -->
                        <Border Style="{StaticResource Card}" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="CLOUDFLARE API TOKEN" Style="{StaticResource SectionLabel}" />
                                <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                                           Text="Needs Zone:Read + DNS:Edit on the zones you manage. Create one with the 'Edit zone DNS' template in the Cloudflare dashboard." />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <PasswordBox x:Name="TokenBox"
                                                     Visibility="{Binding ShowToken, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />
                                        <TextBox x:Name="TokenTextBox" Text="{Binding ApiToken, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="{StaticResource MonoFont}"
                                                 Visibility="{Binding ShowToken, Converter={StaticResource BoolToVis}}" />
                                    </Grid>
                                    <CheckBox Grid.Column="1" Style="{StaticResource Switch}" Content="Show"
                                              IsChecked="{Binding ShowToken}" Margin="14,0,0,0" VerticalAlignment="Center" />
                                    <Button Grid.Column="2" Content="Test token" Style="{StaticResource Ghost}"
                                            Margin="12,0,0,0" Command="{Binding TestTokenCommand}" />
                                </Grid>
                                <TextBlock Text="{Binding TokenSummary}" Style="{StaticResource Muted}" Margin="2,8,0,0" />
                                <TextBlock Text="{Binding TokenTestResult}" TextWrapping="Wrap" Margin="2,6,0,0"
                                           Visibility="{Binding TokenTestResult, Converter={StaticResource NotEmptyToVis}}"
                                           Foreground="{Binding TokenTestKey, Converter={StaticResource StatusToBrush}}" />
                            </StackPanel>
                        </Border>

                        <!-- Behavior -->
                        <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock Text="BEHAVIOR" Style="{StaticResource SectionLabel}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Hostname source" Style="{StaticResource Muted}" Margin="0,0,0,5" />
                                        <ComboBox ItemsSource="{Binding HostnameSources}" SelectedItem="{Binding HostnameSource}" />
                                        <TextBlock Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="2,6,0,0"
                                                   Text="Iis = read IIS bindings · Static = the list below · Both = union" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Check interval (h:mm:ss)" Style="{StaticResource Muted}" Margin="0,0,0,5" />
                                        <TextBox Text="{Binding Interval, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="2,6,0,0"
                                                   Text="e.g. 01:00:00 = hourly (min 1 minute)" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Record TTL (seconds)" Style="{StaticResource Muted}" Margin="0,0,0,5" />
                                        <TextBox Text="{Binding RecordTtl, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="2,6,0,0"
                                                   Text="1 = automatic, otherwise ≥ 60. New records only." />
                                    </StackPanel>
                                </Grid>

                                <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,16,0,14" />

                                <StackPanel Orientation="Horizontal">
                                    <CheckBox Style="{StaticResource Switch}" Content="Proxied (orange-cloud new records)"
                                              IsChecked="{Binding Proxied}" Margin="0,0,34,0" />
                                    <CheckBox Style="{StaticResource Switch}" Content="Create missing records"
                                              IsChecked="{Binding CreateIfMissing}" Margin="0,0,34,0" />
                                    <CheckBox Style="{StaticResource Switch}" Content="Dry run (never write)"
                                              IsChecked="{Binding DryRun}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Hostnames + Exclude -->
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="HOSTNAMES" Style="{StaticResource SectionLabel}" />
                                        <Button Content="+ Add" Style="{StaticResource Chip}" HorizontalAlignment="Right"
                                                Command="{Binding AddHostnameCommand}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding Hostnames}" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                                    <Button Grid.Column="1" Content="✕" Style="{StaticResource Chip}" Margin="6,0,0,0"
                                                            Command="{Binding DataContext.RemoveHostnameCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="2,2,0,0"
                                               Text="Used when source is Static or Both." />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource Card}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="EXCLUDE HOSTNAMES" Style="{StaticResource SectionLabel}" />
                                        <Button Content="+ Add" Style="{StaticResource Chip}" HorizontalAlignment="Right"
                                                Command="{Binding AddExcludeCommand}" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding ExcludeHostnames}" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                                    <Button Grid.Column="1" Content="✕" Style="{StaticResource Chip}" Margin="6,0,0,0"
                                                            Command="{Binding DataContext.RemoveExcludeCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="2,2,0,0"
                                               Text="Never touched, even if present in IIS." />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- IP providers -->
                        <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="PUBLIC-IP PROVIDERS" Style="{StaticResource SectionLabel}" />
                                    <Button Content="+ Add" Style="{StaticResource Chip}" HorizontalAlignment="Right"
                                            Command="{Binding AddProviderCommand}" />
                                </Grid>
                                <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="0,0,0,8"
                                           Text="Queried in order; the first that returns a valid IPv4 wins." />
                                <ItemsControl ItemsSource="{Binding IpProviders}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                         FontFamily="{StaticResource MonoFont}" />
                                                <Button Grid.Column="1" Content="✕" Style="{StaticResource Chip}" Margin="6,0,0,0"
                                                        Command="{Binding DataContext.RemoveProviderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- State file -->
                        <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock Text="STATE FILE" Style="{StaticResource SectionLabel}" />
                                <TextBox Text="{Binding StateFile, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="{StaticResource MonoFont}" />
                                <TextBlock Style="{StaticResource Muted}" FontSize="11" Margin="2,6,0,0"
                                           Text="Where the last-known IP is cached so unchanged runs skip Cloudflare." />
                            </StackPanel>
                        </Border>

                        <!-- Advanced raw JSON -->
                        <Expander Header="Advanced — edit the raw config files" Margin="2,16,0,0" Foreground="{StaticResource MutedBrush}">
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="{Binding LocalFilePath, StringFormat='Local overrides · {0}'}" Style="{StaticResource Muted}" />
                                <TextBox Text="{Binding RawLocalJson, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="{StaticResource MonoFont}" FontSize="12" AcceptsReturn="True"
                                         AcceptsTab="True" VerticalScrollBarVisibility="Auto" Height="180" Margin="0,4,0,0"
                                         TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" />
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Content="Save local JSON" Style="{StaticResource Ghost}" Command="{Binding SaveRawLocalCommand}" />
                                    <Button Content="Reload" Style="{StaticResource Chip}" Margin="8,0,0,0" Command="{Binding ReloadRawCommand}" />
                                </StackPanel>

                                <TextBlock Text="{Binding BaseFilePath, StringFormat='Base defaults · {0}'}" Style="{StaticResource Muted}" Margin="0,16,0,0" />
                                <TextBox Text="{Binding RawBaseJson, UpdateSourceTrigger=PropertyChanged}"
                                         FontFamily="{StaticResource MonoFont}" FontSize="12" AcceptsReturn="True"
                                         AcceptsTab="True" VerticalScrollBarVisibility="Auto" Height="180" Margin="0,4,0,0"
                                         TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" />
                                <Button Content="Save base JSON" Style="{StaticResource Ghost}" Command="{Binding SaveRawBaseCommand}"
                                        HorizontalAlignment="Left" Margin="0,8,0,0" />
                            </StackPanel>
                        </Expander>

                        <!-- Save bar -->
                        <Border Style="{StaticResource Card}" Margin="0,14,0,20" Background="{StaticResource PanelBrush}">
                            <Grid>
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource Muted}" TextWrapping="Wrap"
                                           Text="Changes are written to appsettings.local.json. Restart the service to apply." />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Reload" Style="{StaticResource Ghost}" Command="{Binding ReloadConfigCommand}" />
                                    <Button Content="Save configuration" Style="{StaticResource Primary}" Margin="10,0,0,0"
                                            Command="{Binding SaveConfigCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ───────────── Logs ───────────── -->
            <TabItem Header="Activity log">
                <Grid Margin="8,14,8,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,10">
                        <TextBlock Text="Live activity" Style="{StaticResource H2}" VerticalAlignment="Center" />
                        <TextBlock Text="streams every sync / dry-run in real time" Style="{StaticResource Muted}"
                                   VerticalAlignment="Center" Margin="12,0,0,0" />
                        <Button Content="Open log folder" Style="{StaticResource Chip}" Margin="24,0,0,0"
                                Command="{Binding OpenLogsFolderCommand}" />
                        <Button Content="Clear" Style="{StaticResource Chip}" Margin="8,0,0,0"
                                Command="{Binding ClearLogCommand}" />
                    </StackPanel>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Background="#0B0E12" Padding="4">
                        <ListBox x:Name="LogList" ItemsSource="{Binding Logs}" Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 VirtualizingStackPanel.IsVirtualizing="True">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="Transparent" Padding="8,2">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Time}" FontFamily="{StaticResource MonoFont}" FontSize="12"
                                                   Foreground="{StaticResource MutedBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding ShortLevel}" FontFamily="{StaticResource MonoFont}"
                                                   FontSize="12" FontWeight="Bold" Width="34" TextAlignment="Center" Margin="10,0"
                                                   Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}" />
                                        <TextBlock Grid.Column="2" Text="{Binding Display}" FontFamily="{StaticResource MonoFont}"
                                                   FontSize="12.5" TextWrapping="Wrap"
                                                   Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ───────────── Service ───────────── -->
            <TabItem Header="Service">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,10,8,8">
                    <StackPanel MaxWidth="900" HorizontalAlignment="Left">

                        <Border Style="{StaticResource Card}" Margin="0,4,0,0">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="WINDOWS SERVICE" Style="{StaticResource SectionLabel}" />
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="12" Height="12" VerticalAlignment="Center"
                                                 Fill="{Binding ServiceStatusKey, Converter={StaticResource StatusToBrush}}" />
                                        <TextBlock Text="{Binding ServiceStatus}" Style="{StaticResource H1}" FontSize="20" Margin="10,0,0,0" />
                                    </StackPanel>
                                    <TextBlock Text="CloudflareDdns · LocalSystem · auto-start" Style="{StaticResource Muted}" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="Start" Style="{StaticResource Ghost}" Width="86" Command="{Binding StartServiceCommand}" />
                                    <Button Content="Stop" Style="{StaticResource Ghost}" Width="86" Margin="8,0,0,0" Command="{Binding StopServiceCommand}" />
                                    <Button Content="Restart" Style="{StaticResource Primary}" Width="96" Margin="8,0,0,0" Command="{Binding RestartServiceCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,14,0,0">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="INSTALL / UNINSTALL" Style="{StaticResource SectionLabel}" />
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" MaxWidth="560" HorizontalAlignment="Left"
                                               Text="Install publishes a Release build to Program Files, registers the service (auto-start + auto-restart on failure) and starts it. Both actions prompt for elevation." />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="Install / update" Style="{StaticResource Primary}" Command="{Binding InstallServiceCommand}" />
                                    <Button Content="Uninstall" Style="{StaticResource Danger}" Margin="8,0,0,0" Command="{Binding UninstallServiceCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,14,0,20">
                            <StackPanel>
                                <TextBlock Text="LOCATIONS" Style="{StaticResource SectionLabel}" />
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Config" Style="{StaticResource Muted}" Width="70" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding ConfigPath}" Style="{StaticResource Mono}" FontSize="12"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <Button Grid.Column="2" Content="Open" Style="{StaticResource Chip}" Command="{Binding OpenConfigFolderCommand}" />
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Logs" Style="{StaticResource Muted}" Width="70" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="C:\ProgramData\CloudflareDdns\logs" Style="{StaticResource Mono}" FontSize="12" VerticalAlignment="Center" />
                                    <Button Grid.Column="2" Content="Open" Style="{StaticResource Chip}" Command="{Binding OpenLogsFolderCommand}" />
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="State" Style="{StaticResource Muted}" Width="70" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding StateFile}" Style="{StaticResource Mono}" FontSize="12"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <Button Grid.Column="2" Content="Open" Style="{StaticResource Chip}" Command="{Binding OpenStateFileCommand}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- ══════════════════════════ Status bar ══════════════════════════ -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="18,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding StatusKey, Converter={StaticResource StatusToBrush}}" />
                    <TextBlock Text="{Binding StatusMessage}" Margin="9,0,0,0" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" MaxWidth="720" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding BusyText}" Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <ProgressBar IsIndeterminate="True" Width="140" Height="4" Foreground="{StaticResource AccentBrush}"
                                 Background="{StaticResource BorderBrush}" BorderThickness="0" />
                </StackPanel>

                <TextBlock Grid.Column="2" Text="{Binding ConfigPath}" Style="{StaticResource Muted}" FontSize="11"
                           VerticalAlignment="Center" Margin="16,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="360" />
            </Grid>
        </Border>
    </Grid>
</Window>
